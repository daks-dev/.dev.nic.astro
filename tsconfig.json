{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strictNullChecks": true,
    "checkJs": true,
    "verbatimModuleSyntax": true,
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ],
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@assets/*": ["src/assets/*"],
      "@lib/*": ["src/lib/*"],
      "@layouts/*": ["src/layouts/*"],
      "@styles/*": ["src/styles/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "*.ts",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.astro",
    "src/**/*.svelte"
  ],
  "exclude": ["build/", "dist/", "node_modules/"]
}
