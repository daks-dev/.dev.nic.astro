---
import { getImage } from 'astro:assets';
import LightboxData from '../../svelte/lightbox/LightboxData.svelte';
import type { LightboxDataAttributes } from '../../svelte/lightbox/index.d.ts';
import type { BindImageData } from './index.d.ts';

type Props = Omit<LightboxDataAttributes, 'data'> & {
  data: BindImageData | BindImageData[];
  transform: {
    [x in 'thumb' | 'modal']: ImageTransform;
  };
  filter?: string[];
  client?: 'load' | 'idle' | 'visible'; // | (string & NonNullable<unknown>)
};

const { data: __data, transform, filter, client = 'visible', ...props } = Astro.props;

const data: {
  thumb: ImageResult;
  modal: ImageResult;
  alt?: string;
  caption?: Record<string, string>;
}[] = [];

const load = async (x: BindImageData) => {
  if ('data' in x && x.data) {
    for (const { image, alt, caption: __caption = {} } of x.data) {
      const t = await getImage({
        src: image,
        ...transform.thumb
      });
      const m = await getImage({
        src: image,
        ...transform.modal
      });
      const caption = Object.entries(__caption).reduce(
        (acc, [key, val]) => (
          (filter === undefined || filter.includes(key)) && (acc[key] = val), acc
        ),
        {} as Record<string, string>
      );
      data.push({
        thumb: {
          src: t.src,
          attributes: t.attributes
        },
        modal: {
          src: m.src,
          attributes: m.attributes
        },
        alt,
        caption
      });
    }
  } else if ('src' in x) {
    const t = await getImage({
      src: x,
      ...transform.thumb
    });
    const m = await getImage({
      src: x.src,
      ...transform.modal
    });
    data.push({
      thumb: {
        src: t.src,
        attributes: t.attributes
      },
      modal: {
        src: m.src,
        attributes: m.attributes
      }
    });
  }
};

if (__data instanceof Array) for (const x of __data) await load(x);
else await load(__data);
---

{
  client === 'visible' ? (
    <LightboxData
      {data}
      {...props}
      client:visible
    />
  ) : client === 'idle' ? (
    <LightboxData
      {data}
      {...props}
      client:idle
    />
  ) : (
    <LightboxData
      {data}
      {...props}
      client:load
    />
  )
}
