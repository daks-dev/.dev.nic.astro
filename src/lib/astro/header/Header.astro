---
import { twMerge } from '../../tailwind/tailwind-merge.js';
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'div'>, 'class'> {
  tag?: 'header' | 'div';
  class?: ClassValue;
  tagline?: string;
  align?: 'start' | 'center';
}

const {
  tag: Element = 'header',
  class: className,
  title,
  tagline,
  align = 'center',
  ...props
} = Astro.props;
---

<Element
  class={twMerge(
    'flex flex-col gap-4',
    'bp:text-2xl text-center text-xl',
    align === 'start' && 'bp:text-start',
    className
  )}
  {...props}>
  <div class='flex flex-col gap-2'>
    <h1
      class:list={[
        'mx-auto mb-4 max-w-[37ch]',
        'bp:text-7xl text-4xl sm:text-5xl',
        align === 'start' && 'bp:mx-unset'
      ]}>
      <slot name='title'>
        <Fragment set:html={title} />
      </slot>
    </h1>
    <slot name='tagline'>
      {
        tagline && (
          <p
            class:list={['mx-auto mb-2 max-w-[37ch]', align === 'start' && 'bp:mx-0']}
            set:html={tagline}
          />
        )
      }
    </slot>
  </div>
  <slot />
</Element>
