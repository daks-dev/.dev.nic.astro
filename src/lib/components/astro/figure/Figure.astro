---
import { twMerge } from '../../../tailwind/tailwind-merge.js';
import placeholder from '../../../assets/images/placeholder';
import type { HTMLAttributes } from 'astro/types';

type ImgAttriibutes = Omit<HTMLAttributes<'img'>, 'src' | 'class'>;

type Props = Omit<HTMLAttributes<'figure'>, 'class'> & {
  image: string | ImageResult;
  img?: ImgAttriibutes;
  caption?: Record<string, string | undefined>;
  class?: ClassValue;
  custom?: Record<string, ClassValue>;
  alt?: string;
  native?: true;
};

const {
  image: __image,
  img,
  caption: __caption = {},
  class: className,
  custom = {},
  alt = img?.alt ?? '',
  native,
  ...props
} = Astro.props;

const image = typeof __image === 'string' ? { src: __image } : __image;
const attributes = Object.assign(
  {
    itemprop: 'image',
    loading: 'lazy',
    decoding: 'async'
  },
  image.attributes,
  img,
  { alt }
);

const caption = Object.entries(__caption);
---

<figure
  class={twMerge('relative flex flex-col', className)}
  {...props}>
  <slot name='before' />
  <img
    class={twMerge(!native && 'lazy', custom.img)}
    src={native ? image.src : placeholder}
    data-src={native ? undefined : image.src}
    {...attributes}
  />
  <slot>
    {
      caption.length && (
        <figcaption class={twMerge('flex flex-col', custom.caption)}>
          {caption.map(([key, val]) =>
            key === 'title' ? (
              <span
                class={twMerge('order-first font-semibold', custom[key])}
                set:html={val}
              />
            ) : key === 'description' ? (
              <small
                class={twMerge('order-last', custom[key])}
                set:html={val}
              />
            ) : (
              <span
                class={twMerge(custom[key])}
                set:html={val}
              />
            )
          )}
        </figcaption>
      )
    }
  </slot>
  <slot name='after' />
</figure>
