---
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { Figure, Sign } from '@lib/astro';
import { Header } from '@components/astro';
import Layout from '@layouts/Base.astro';

import logo from '@assets/images/logo.webp';
const placeholder = await getImage({ src: logo, width: 288, height: 288, fit: 'inset' });

const collection = await getCollection('projects');

const gallery = (
  await Promise.all(
    collection.map(async ({ id, data: { images, title, description } }) => {
      const src = images?.length
        ? await getImage({
            src: images[0].src,
            width: 288,
            height: 288,
            fit: 'cover'
          })
        : placeholder;
      return {
        id,
        src,
        caption: {
          title,
          description
        }
      };
    })
  )
).sort((a, b) => a.id.localeCompare(b.id));

const title = 'Проекты';
---

<Layout
  title={`${title} • НИЦ «Строительная экспертиза»`}
  description={`${title} • АО НИЦ «Строительная Экспертиза»`}>
  <Header {title} />

  <main
    class='frame'
    itemprop='mainContentOfPage'>
    <div
      class:list={[
        'grid gap-x-8 gap-y-12 max-sm:place-items-center lg:gap-16',
        'grid-cols-1 sm:grid-cols-2 md:grid-cols-3'
      ]}>
      {
        gallery.map(({ id, src, caption }) => (
          <a
            class='group relative'
            href={`/projects/${id}`}>
            <Sign
              icon='link'
              class='left-2 top-2'
              link
              dark
            />
            <Figure
              class:list={[
                'overflow-hidden',
                'rounded-sm border border-gray-400 dark:border-gray-600',
                'shadow-md shadow-black group-hover:shadow-sm',
                'pointer-events-none',
                'transition-easy'
              ]}
              custom={{
                img: [
                  'h-auto w-full max-w-full',
                  'transition-easy grayscale group-hover:grayscale-0'
                ],
                caption: [
                  'absolute bottom-0 left-0',
                  'h-20 w-full overflow-hidden p-2',
                  'flex flex-col justify-start',
                  'text-ellipsis leading-tight text-white',
                  'bg-gray-700/70',
                  'group-hover:opacity-0',
                  'transition-opacity duration-1000 ease-in-out'
                ]
              }}
              {src}
              {caption}
            />
            <small class='absolute right-2 top-2 text-black'>{id}</small>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
