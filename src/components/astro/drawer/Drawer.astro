---
import { twMerge } from '@lib';
import { Icon } from '@lib/astro';
import Menu from './Menu.astro';
import type { HTMLAttributes } from 'astro/types';

type Props = Omit<HTMLAttributes<'aside'>, 'class' | 'aria-owns'> & {
  class?: ClassValue;
};

const { class: className, ...props } = Astro.props;
---

<aside
  is='app-drawer'
  id='app-drawer'
  class={twMerge(
    'top-(--navbar-height) w-(--drawer-width) fixed bottom-0 z-40',
    'not-aria-hidden:translate-x-0 2xl:-translate-x-[(100%_-_3rem)] -translate-x-full',
    'flex',
    'overflow-hidden',
    'bg-theme-frame shadow-xl shadow-gray-300 dark:shadow-gray-950',
    'border-gray-700/50 dark:border-l',
    'motion-safe:ready:transition-transform duration-200 ease-in-out',
    className
  )}
  aria-owns='app-drawer-toggle'
  aria-hidden='true'
  {...props}>
  <Menu class='grow overflow-y-auto pb-8 pt-4' />

  <div
    class:list={[
      'flex flex-col items-center gap-y-3',
      'w-12 py-4',
      'text-theme-link',
      'border-l border-gray-200 dark:border-gray-700/50'
    ]}>
    <a
      class='p-2'
      href='#'>
      <Icon
        icon='phone-call'
        size='1.5em'
      />
    </a>
    <a
      class='p-2'
      href='#'>
      <Icon
        icon='envelope'
        size='1.5em'
      />
    </a>
  </div>
</aside>

<script>
  import { $drawer } from './store';

  class AppDrawer extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      $drawer.listen((x) => this.setAttribute('aria-hidden', String(!x)));
      document.addEventListener('click', this.outside);
    }

    disconnectedCallback() {
      $drawer.off();
      document.removeEventListener('click', this.outside);
    }

    outside = (e: Event) => {
      if (e?.target && !e.defaultPrevented && !this.contains(e.target as Node)) $drawer.set(false);
    };
  }

  customElements.define('app-drawer', AppDrawer, { extends: 'aside' });
</script>
