---
import { Image } from 'astro:assets';
import { Link } from '@lib/components/astro';
import MenuToggle from './MenuToggle.astro';
import DrawerToggle from './DrawerToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import ToTop from './ToTop.astro';

import logo from '@assets/images/logo.icon.webp';

import { nav } from '@app/configs/nav';
---

<nav
  id='app-navbar'
  class:list={[
    'fixed inset-x-0 z-50',
    'h-(--navbar-height) px-5 py-3',
    'grid grid-cols-[1fr_auto] place-content-center gap-x-3',
    'bp:grid-cols-[1fr_auto_1fr]',
    'bg-theme-inner',
    'onscroll:shadow-md shadow-xs shadow-gray-200 dark:shadow-gray-900',
    'border-b border-gray-100 dark:border-gray-900'
  ]}>
  <div class:list={['flex items-center justify-between', 'menu-header']}>
    <div class='-ml-3.5 flex items-center gap-7'>
      <DrawerToggle />
      <Link
        class:list={[
          'group',
          'flex items-center gap-4',
          'text-base/tight font-medium',
          'transition duration-200'
        ]}
        href='/'
        prefetch>
        <Image
          class:list={[
            'drop-shadow-2xl',
            'group-hover:drop-shadow-deep',
            'animate-[wiggle_20s_ease-in-out_infinite]'
          ]}
          src={logo}
          width={40}
          height={40}
          loading='eager'
          alt='ниц «строительная экспертиза»'
        />
        <!--div class:list={['hidden', 'xs:max-bp:block 3xl:block']}>
          АО НИЦ <br /> «Строительная Экспертиза»
        </div-->
      </Link>
    </div>
    <MenuToggle />
  </div>
  <div
    id='app-navbar-menu'
    class:list={['bp:contents absolute inset-x-0', 'max-bp:top-(--navbar-height)']}
    aria-owns='app-navbar-menu-toggle'
    hidden>
    <menu
      class:list={[
        'relative',
        // 'bp:py-1.5',
        'flex flex-col',
        'bp:flex-row bp:gap-x-3',
        'text-lg font-normal',
        'bp:text-base',
        'max-bp:bg-theme-inner'
      ]}>
      {
        nav.navbar.map(({ class: className, ...props }) => (
          <li class:list={['relative flex flex-col', className]}>
            <Link
              class:list='inner'
              {...props}
            />
          </li>
        ))
      }
    </menu>
    <div
      class:list={[
        // 'max-bp:py-2',
        'flex justify-around',
        'bp:items-center bp:justify-self-end',
        'bg-theme-inner',
        'rounded-b-md',
        'shadow-md dark:shadow-gray-800',
        'bp:shadow-none',
        'bp:bg-transparent'
      ]}>
      {
        /*
        outers && (
          <div class:list={['flex flex-wrap gap-x-3', 'bp:hidden xl:flex xl:justify-end xl:gap-0']}>
            {outers.map(({ class: className, ...props }) => (
              <Link
                class:list={['outer', className]}
                size='1.625rem'
                {...props}
              />
            ))}
          </div>
        )
      */
      }
      <div class='flex items-center'>
        <ThemeToggle />
      </div>
    </div>
  </div>

  <ToTop
    class:list={['mt-8 w-14 p-3', 'bg-primary-500/50 dark:bg-primary-700/50', 'rounded-full']}
  />
</nav>

<style scoped>
  @reference "@styles/global.css";

  .inner {
    @apply px-4 py-2;
    @apply bp:px-3 bp:pt-1 bp:pb-1.5;
    @apply text-theme-plain;
    @apply step:text-theme-header step:border-theme-header;
    @apply page:text-impact-hard bp:page:text-white dark:bp:page:text-black bp:page:bg-primary-400;
    @apply hover:bg-primary-300 dark:hover:bg-primary-500 hover:text-primary-900 dark:hover:text-primary-200;
    @apply bp:border bp:rounded-full border-transparent;
    @apply bp:ready:transition-colors bp:ready:duration-200;
    @apply forced-colors:text-selected;
  }

  .outer {
    @apply text-impact-hard dark:text-impact-hard ready:transition-colors ready:duration-200 hover:text-impact-text dark:hover:text-impact-text flex p-2 no-underline;
  }
</style>
